{
  "manifest_version": 3,
  "name": "NovaTab - Productive New Tab",
  "version": "1.0.0",
  "description": "Beautiful new tab with clock, weather, todos, quotes & focus timer. Free alternative to Momentum Plus.",
  "permissions": ["storage", "geolocation"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
