{
  "manifest_version": 3,
  "name": "NovaRecorder - Free Screen Recorder",
  "version": "1.0.0",
  "description": "Free unlimited screen & tab recorder. Record, download as WebM/MP4. No time limits, no watermarks. Free alternative to Loom.",
  "permissions": ["activeTab", "storage", "tabs", "scripting", "desktopCapture"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NovaRecorder - Record Screen"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
